# Required. From @BotFather.
BOT_TOKEN=

# Required. Numeric chat id (recommended, looks like -1001234567890) or @channel.
# The numeric id keeps working even if the channel username changes later.
CHANNEL_CHAT_ID=

# Optional. The channel's public link, shown by /start in DM.
# If unset, the bot falls back to deriving it from @username (when used).
CHANNEL_PUBLIC_URL=

# Optional. Your Telegram user id (numeric). Unlocks the /admin commands.
ADMIN_TELEGRAM_ID=

# Optional. Cron timezone for the daily schedules. Defaults to UTC.
# Examples: Africa/Cairo, Europe/London, America/New_York, Asia/Riyadh.
TZ_NAME=Africa/Cairo

# Optional. production for hosted, anything else (or unset) is dev.
NODE_ENV=

# Optional. Port for the /health HTTP endpoint. Defaults to 8080.
PORT=

# Optional. Override the daily schedule cron expressions if you do not
# like the defaults. Each follows the standard 5-field crontab format.
# Warm-up question default: 15:00 (after school). Challenge default: 19:30.
# Check-in poll default: 17:30 (the "did you practice math today?" nudge).
WARMUP_CRON=
CHALLENGE_CRON=
CHECKIN_POLL_CRON=

# Optional. Path to the tiny JSON pointer file that remembers the last
# check-in poll message id, so the replace-on-next-fire delete survives
# a restart. Default ./data/last-message-ids.json.
STATE_FILE=
