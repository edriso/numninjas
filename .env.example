# Required. From @BotFather.
BOT_TOKEN=

# Required. Numeric chat id (recommended, looks like -1001234567890) or @channel.
# The numeric id keeps working even if the channel username changes later.
CHANNEL_CHAT_ID=

# Optional. The channel's public link, shown by /start in DM.
# If unset, the bot falls back to deriving it from @username (when used).
CHANNEL_PUBLIC_URL=

# Optional. Your Telegram user id (numeric). Unlocks the /admin commands.
ADMIN_TELEGRAM_ID=

# Optional. Cron timezone for the daily schedule. Defaults to UTC.
# Examples: Africa/Cairo, Europe/London, America/New_York, Asia/Riyadh.
TZ_NAME=Africa/Cairo

# Optional. production for hosted, anything else (or unset) is dev.
NODE_ENV=

# Optional. Port for the /health HTTP endpoint. Defaults to 8080.
PORT=

# Optional. Override the single daily fire (5-field crontab format).
# Default is 07:00: a morning warm-up + challenge that reward waking
# early and post nothing at night. Both questions go out at this time.
DAILY_CRON=
